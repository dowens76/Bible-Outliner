{
  "manifest_version": 3,
  "name": "__MSG_appName__",
  "version": "0.1.1",
  "description": "__MSG_appDescription__",
  "default_locale": "en",
  "permissions": [
    "storage",
    "sidePanel",
    "scripting",
    "tabs",
    "activeTab",
    "downloads",
    "identity"
  ],
  "host_permissions": [
    "https://www.stepbible.org/*",
    "https://www.bible.com/*",
    "https://www.biblegateway.com/*",
    "https://parabible.com/*",
    "https://www.googleapis.com/*",
    "https://oauth2.googleapis.com/*"
  ],
  "action": {
    "default_title": "__MSG_togglePanel__"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": ["https://www.stepbible.org/*"],
      "js": ["content.js"],
      "run_at": "document_end",
      "all_frames": true
    },
    {
      "matches": ["https://www.bible.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.biblegateway.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://parabible.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
